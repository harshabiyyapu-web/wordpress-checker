      "id": "aa000002-0000-4000-8000-000000000002",
      "name": "OpenRouter Model (Rewriter)",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenRouter",
      "typeVersion": 1,
      "position": [
        1584,
        460
      ],
      "credentials": {
        "openRouterApi": {
          "id": "KiYJKf1eAKn8w42w",
          "name": "OpenRouter account"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "function slugifyShort(input) {\n  const base = (input || '')\n    .toLowerCase()\n    .replace(/[^a-z0-9\\s-]/g, '')\n    .trim()\n    .replace(/\\s+/g, '-')\n    .replace(/-+/g, '-')\n    .slice(0, 45)\n    .replace(/-+$/, '');\n\n  const stamp = Date.now().toString().slice(-6);\n  return `${base || 'post'}-${stamp}`;\n}\n\n// chainLlm outputs the response in $json.text\nconst rewritten = $json.text || '';\nconst prepared = $('Prepare Content').item.json;\n\nif (!rewritten) {\n  throw new Error('OpenRouter returned empty content — stopping item to prevent partial post');\n}\n\nreturn {\n  json: {\n    sourceUrl: prepared.sourceUrl,\n    originalTitle: prepared.originalTitle,\n    imageUrl: prepared.imageUrl,\n    rewrittenHtml: rewritten,\n    slug: slugifyShort(prepared.originalTitle),\n  },\n};"
      },
      "id": "1eb110fe-eaa0-4f03-b529-b816c0fca0d6",
