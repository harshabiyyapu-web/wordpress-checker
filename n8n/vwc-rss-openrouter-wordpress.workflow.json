      "id": "loop0001-0000-4000-8000-000000000001",
      "name": "Split In Batches",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        704,
        272
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nstaticData.seen = staticData.seen || {};\n\nconst output = [];\n\nfor (const item of $input.all()) {\n  const url = item.json.link || item.json.guid || item.json.id;\n  if (!url) continue;\n  if (staticData.seen[url]) continue;\n\n  staticData.seen[url] = new Date().toISOString();\n\n  output.push({\n    json: {\n      sourceUrl: url,\n      rssTitle: item.json.title || '',\n      rssPubDate: item.json.isoDate || item.json.pubDate || '',\n    },\n  });\n}\n\nreturn output;"
      },
      "id": "9435e628-0469-4e36-b7ee-c6545b70f7ec",
      "name": "Filter New URLs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        704,
        80
      ]
    },
    {
      "parameters": {
        "url": "={{ $json.sourceUrl }}",
        "options": {
