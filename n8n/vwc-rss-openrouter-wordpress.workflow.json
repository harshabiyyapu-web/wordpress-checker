        "text": "={{ $json.rewritePrompt }}",
        "batching": {}
      },
      "id": "aa000001-0000-4000-8000-000000000001",
      "name": "Rewrite With OpenRouter",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.7,
      "position": [
